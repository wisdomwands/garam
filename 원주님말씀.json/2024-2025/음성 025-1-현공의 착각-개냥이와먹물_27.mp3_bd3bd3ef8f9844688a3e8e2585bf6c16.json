대가통이 얇아서 얇아서 그러 그래서 제가 주인을 알아보지 못한 너 땜에 주인을 따르고 복종하며 의리가 있고 그 밑에 수그리지 못하는 그 습성 때문에 그게 고양이 애들이야.","confidence":0.9069314,"speakers":[{"label":"1","name":"A","edited":false},{"label":"2","name":"B","edited":false},{"label":"3","name":"C","edited":false},{"label":"4","name":"D","edited":false}],"events":[],"eventTypes":[]}